{
  "name": "reportpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src next.config.ts vitest.config.ts eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "worker:imports": "tsx src/workers/import-worker.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "nanoid": "^5.1.5",
    "next": "^15.5.4",
    "next-auth": "5.0.0-beta.29",
    "openai": "^5.23.1",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.5.2",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "prisma": "^6.16.3",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.5",
    "@eslint/eslintrc": "^3.3.1",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
